# Copy this file to `.env` and fill in real values.
# Never commit .env itself (see .gitignore).

# --- DockerHub ---
DOCKERHUB_USER=htasteqin
CONSUMER_IMAGE=${DOCKERHUB_USER}/cs5296-consumer:v1.0

# --- AWS EC2 ---
EC2_PUBLIC_IP=CHANGEME
EC2_SSH_KEY=~/.ssh/cs5296.pem

# --- RabbitMQ (inside cluster) ---
RABBITMQ_HOST=rabbitmq.rabbitmq.svc.cluster.local
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASS=cs5296-demo

# --- Scaling thresholds ---
HPA_CPU_TARGET=50
KEDA_QUEUE_LENGTH=100
MIN_REPLICAS=1
MAX_REPLICAS=10

# --- Experiment parameters ---
BURST_TOTAL_MESSAGES=10000
BURST_RATE_PER_SEC=1000
OBSERVATION_DURATION_SEC=180
